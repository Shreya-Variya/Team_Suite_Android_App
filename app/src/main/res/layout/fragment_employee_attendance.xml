<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.employee.EmployeeAttendanceFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/attendance_layout_padding">

        <TextView
            android:id="@+id/txtAttendanceTitle"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:text="@string/your_attendance_report"
            android:textStyle="bold"
            android:textSize="@dimen/attendance_header_txt"
            android:gravity="center"
            android:textColor="?attr/colorOnBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="@dimen/common_margin"/>

        <TextView
            android:id="@+id/txtHeaderDate"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_margin"
            android:gravity="center"
            android:text="@string/date"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/txtAttendanceTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/txtHeaderStatus"
            app:layout_constraintHorizontal_weight="1.1"/>

        <TextView
            android:id="@+id/txtHeaderStatus"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_margin"
            android:gravity="center"
            android:text="@string/status"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/txtAttendanceTitle"
            app:layout_constraintStart_toEndOf="@+id/txtHeaderDate"
            app:layout_constraintEnd_toStartOf="@+id/txtHeaderWork"
            app:layout_constraintHorizontal_weight="1"/>

        <TextView
            android:id="@+id/txtHeaderWork"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_margin"
            android:gravity="center"
            android:text="@string/work"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/txtAttendanceTitle"
            app:layout_constraintStart_toEndOf="@+id/txtHeaderStatus"
            app:layout_constraintEnd_toStartOf="@+id/txtHeaderBreak"
            app:layout_constraintHorizontal_weight="1"/>

        <TextView
            android:id="@+id/txtHeaderBreak"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_margin"
            android:gravity="center"
            android:text="@string/_break"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/txtAttendanceTitle"
            app:layout_constraintStart_toEndOf="@+id/txtHeaderWork"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"/>

        <View
            android:id="@+id/divider"
            android:layout_width="@dimen/no_width"
            android:layout_height="@dimen/divider_height"
            android:background="@android:color/darker_gray"
            app:layout_constraintTop_toBottomOf="@id/txtHeaderDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/attendance_margin_top"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAttendance"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/attendance_margin_top"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>