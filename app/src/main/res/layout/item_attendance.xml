<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="@dimen/attendance_item_padding">

    <TextView
        android:id="@+id/txtDate"
        android:layout_width="@dimen/no_width"
        android:layout_height="wrap_content"
        android:text="@string/demo_date"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/txtStatus"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1.1"/>

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="@dimen/no_width"
        android:layout_height="wrap_content"
        android:text="@string/demo_status"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@+id/txtDate"
        app:layout_constraintEnd_toStartOf="@+id/txtWork"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

    <TextView
        android:id="@+id/txtWork"
        android:layout_width="@dimen/no_width"
        android:layout_height="wrap_content"
        android:text="@string/demo_work"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@+id/txtStatus"
        app:layout_constraintEnd_toStartOf="@+id/txtBreak"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

    <TextView
        android:id="@+id/txtBreak"
        android:layout_width="@dimen/no_width"
        android:layout_height="wrap_content"
        android:text="@string/demo_break"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@+id/txtWork"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

    <View
        android:id="@+id/divider"
        android:layout_width="@dimen/no_width"
        android:layout_height="@dimen/divider_height"
        android:background="@android:color/darker_gray"
        app:layout_constraintTop_toBottomOf="@id/txtDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/attendance_margin_top"/>

</androidx.constraintlayout.widget.ConstraintLayout>