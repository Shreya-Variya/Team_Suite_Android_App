<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/card_default_margin">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/card_default_margin"
        app:cardCornerRadius="@dimen/card_leavepolicy_radius"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        app:cardBackgroundColor="@color/card_default_color"
        tools:ignore="MissingConstraints">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/common_padding">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtLeaveType"
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:text="@string/demo_leave"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/card_title_txt"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtMaxLeaveLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_local_margin"
                android:text="@string/max_leave_year"
                android:textSize="@dimen/card_subtitle_txt"
                android:textColor="@color/card_subtext_color"
                app:layout_constraintTop_toBottomOf="@id/txtLeaveType"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/txtMaxLeaveValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_local_min_margin"
                android:text="@string/demo_max_leave"
                android:textSize="@dimen/common_text_size"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/txtMaxLeaveLabel"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/txtConsecutiveLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_local_margin"
                android:text="@string/max_consecutive_leave"
                android:textSize="@dimen/card_subtitle_txt"
                android:textColor="@color/card_subtext_color"
                app:layout_constraintTop_toBottomOf="@id/txtLeaveType"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/txtConsecutiveValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_local_min_margin"
                android:text="@string/demo_consecutive_leave"
                android:textSize="@dimen/common_text_size"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/txtConsecutiveLabel"
                app:layout_constraintTop_toBottomOf="@id/txtConsecutiveLabel" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>