<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.admin.EmployeeAttendanceReportFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/attendance_layout_padding">

        <!-- DATE FILTER CARD (NOW ON TOP) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDateFilter"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/select_date_radius"
            app:cardElevation="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/attendance_layout_padding"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgCalendar"
                    android:layout_width="@dimen/img_size"
                    android:layout_height="@dimen/img_size"
                    android:src="@drawable/ic_attendance"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/txtSelectedDate"
                    android:layout_width="307dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/select_date"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/img2_size"
                    android:layout_height="@dimen/img2_size"
                    android:src="@drawable/ic_arrow_drop_down"
                    tools:ignore="ContentDescription" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtAttendanceTitle"
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="@dimen/common_margin"
            android:text="@string/today_s_employee_attendance_report"
            android:textColor="?attr/colorOnBackground"
            android:textSize="@dimen/attendance_header_txt"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardDateFilter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <HorizontalScrollView
            android:layout_width="@dimen/no_width"
            android:layout_height="@dimen/no_height"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/txtAttendanceTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/txtHeaderEmpId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/emp_id"
                    android:minWidth="100dp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="MissingConstraints" />

                <TextView
                    android:id="@+id/txtHeaderEmpName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/name"
                    android:textStyle="bold"
                    android:minWidth="100dp"
                    android:gravity="center"
                    android:padding="12dp"
                    app:layout_constraintStart_toEndOf="@+id/txtHeaderEmpId"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="MissingConstraints" />

                <TextView
                    android:id="@+id/txtHeaderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/date"
                    android:textStyle="bold"
                    android:minWidth="100dp"
                    android:padding="12dp"
                    app:layout_constraintStart_toEndOf="@+id/txtHeaderEmpName"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="MissingConstraints" />

                <TextView
                    android:id="@+id/txtHeaderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/status"
                    android:textStyle="bold"
                    android:minWidth="100dp"
                    android:padding="12dp"
                    app:layout_constraintStart_toEndOf="@+id/txtHeaderDate"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="MissingConstraints" />

                <TextView
                    android:id="@+id/txtHeaderWork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/work"
                    android:textStyle="bold"
                    android:minWidth="100dp"
                    android:padding="12dp"
                    android:visibility="gone"
                    app:layout_constraintStart_toEndOf="@+id/txtHeaderStatus"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="MissingConstraints" />

                <TextView
                    android:id="@+id/txtHeaderBreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/_break"
                    android:textStyle="bold"
                    android:minWidth="100dp"
                    android:padding="12dp"
                    android:visibility="gone"
                    app:layout_constraintStart_toEndOf="@+id/txtHeaderWork"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="MissingConstraints" />

                <View
                    android:id="@+id/divider"
                    android:layout_width="@dimen/no_width"
                    android:layout_height="@dimen/divider_height"
                    android:background="@android:color/darker_gray"
                    app:layout_constraintTop_toBottomOf="@id/txtHeaderDate"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="@dimen/attendance_margin_top"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcEmpAttendance"
                    android:layout_width="@dimen/no_width"
                    android:layout_height="@dimen/no_width"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/divider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="@dimen/attendance_margin_top"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </HorizontalScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>