<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/common_padding"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:useDefaultMargins="true"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            app:cardCornerRadius="@dimen/common_card_radius"
            app:cardBackgroundColor="@color/off_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/common_padding"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgEmployeeIcon"
                    android:layout_width="@dimen/card_icon_size"
                    android:layout_height="@dimen/card_icon_size"
                    android:src="@drawable/ic_employee"
                    android:tint="@color/colorPrimary"
                    android:layout_marginEnd="@dimen/common_margin"
                    tools:ignore="ContentDescription,UseAppTint" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtEmployee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/card_text_margin"
                        android:text="@string/employee"
                        android:textSize="@dimen/common_text_size"
                        android:textColor="@color/card_text_color"/>

                    <TextView
                        android:id="@+id/txtTotalEmployee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_employee"
                        android:textSize="@dimen/number_size"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            app:cardCornerRadius="@dimen/common_card_radius"
            app:cardBackgroundColor="@color/off_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/common_padding"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgPresentIcon"
                    android:layout_width="@dimen/card_icon_size"
                    android:layout_height="@dimen/card_icon_size"
                    android:src="@drawable/ic_attendance"
                    android:tint="@color/present_icon_color"
                    android:layout_marginEnd="@dimen/common_margin"
                    tools:ignore="ContentDescription,UseAppTint" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtPresent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/card_text_margin"
                        android:text="@string/present"
                        android:textSize="@dimen/common_text_size"
                        android:textColor="@color/card_text_color"/>

                    <TextView
                        android:id="@+id/txtPresentEmployee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_present"
                        android:textSize="@dimen/number_size"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            app:cardCornerRadius="@dimen/common_card_radius"
            app:cardBackgroundColor="@color/off_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/common_padding"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgLeaveIcon"
                    android:layout_width="@dimen/card_icon_size"
                    android:layout_height="@dimen/card_icon_size"
                    android:src="@drawable/ic_leave"
                    android:tint="@color/leave_icon_color"
                    android:layout_marginEnd="@dimen/common_margin"
                    tools:ignore="ContentDescription,UseAppTint" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtLeave"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/card_text_margin"
                        android:text="@string/on_leave"
                        android:textSize="@dimen/common_text_size"
                        android:textColor="@color/card_text_color"/>

                    <TextView
                        android:id="@+id/txtLeaveEmployee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_leave"
                        android:textSize="@dimen/number_size"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/no_width"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            app:cardCornerRadius="@dimen/common_card_radius"
            app:cardBackgroundColor="@color/off_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/common_padding"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgAbsentIcon"
                    android:layout_width="@dimen/card_icon_size"
                    android:layout_height="@dimen/card_icon_size"
                    android:src="@drawable/ic_absent"
                    android:tint="@color/absent_icon_color"
                    android:layout_marginEnd="@dimen/common_margin"
                    tools:ignore="ContentDescription,UseAppTint" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtAbsent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/card_text_margin"
                        android:text="@string/absent"
                        android:textSize="@dimen/common_text_size"
                        android:textColor="@color/card_text_color"/>

                    <TextView
                        android:id="@+id/txtAbsentEmployee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_absent"
                        android:textSize="@dimen/number_size"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>