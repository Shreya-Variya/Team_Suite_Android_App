<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.employee.ApplyLeaveFormFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/add_employee_background">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/add_emp_screen_padding">

            <TextView
                android:id="@+id/txttitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/apply_for_leave"
                android:textSize="@dimen/add_emp_title"
                android:textStyle="bold"
                android:textColor="@color/title_add_emp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/leaveTypeLayout"
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:hint="@string/leave_type"
                app:boxBackgroundColor="@color/white"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/et_border_radius"
                app:boxCornerRadiusBottomStart="@dimen/et_border_radius"
                app:boxCornerRadiusTopEnd="@dimen/et_border_radius"
                app:boxCornerRadiusTopStart="@dimen/et_border_radius"
                app:boxStrokeColor="@color/et_border"
                app:hintTextAppearance="@style/BigBoldTextInputLabel"
                app:hintTextColor="@color/black"
                app:endIconMode="dropdown_menu"
                app:layout_constraintTop_toBottomOf="@id/txttitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/all_et_top_margin">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etLeaveType"
                    android:inputType="none"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="@dimen/autocompletetextViewpadding"
                    android:textColor="@color/black"
                    android:textSize="@dimen/common_text_size"
                    android:background="@null"
                    tools:ignore="LabelFor" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/startDateLayout"
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:hint="@string/start_date"
                app:boxBackgroundColor="@color/white"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/et_border_radius"
                app:boxCornerRadiusBottomStart="@dimen/et_border_radius"
                app:boxCornerRadiusTopEnd="@dimen/et_border_radius"
                app:boxCornerRadiusTopStart="@dimen/et_border_radius"
                app:boxStrokeColor="@color/et_border"
                app:hintTextAppearance="@style/BigBoldTextInputLabel"
                app:hintTextColor="@color/black"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_attendance"
                app:layout_constraintTop_toBottomOf="@id/leaveTypeLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/all_et_top_margin">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStartDate"
                    android:focusable="false"
                    android:clickable="true"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    tools:ignore="KeyboardInaccessibleWidget" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/endDateLayout"
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:hint="@string/end_date"
                app:boxBackgroundColor="@color/white"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/et_border_radius"
                app:boxCornerRadiusBottomStart="@dimen/et_border_radius"
                app:boxCornerRadiusTopEnd="@dimen/et_border_radius"
                app:boxCornerRadiusTopStart="@dimen/et_border_radius"
                app:boxStrokeColor="@color/et_border"
                app:hintTextAppearance="@style/BigBoldTextInputLabel"
                app:hintTextColor="@color/black"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_attendance"
                app:layout_constraintTop_toBottomOf="@id/startDateLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/all_et_top_margin">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEndDate"
                    android:focusable="false"
                    android:clickable="true"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    tools:ignore="KeyboardInaccessibleWidget" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/reasonLayout"
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:hint="@string/reason"
                app:boxBackgroundColor="@color/white"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/et_border_radius"
                app:boxCornerRadiusBottomStart="@dimen/et_border_radius"
                app:boxCornerRadiusTopEnd="@dimen/et_border_radius"
                app:boxCornerRadiusTopStart="@dimen/et_border_radius"
                app:boxStrokeColor="@color/et_border"
                app:hintTextAppearance="@style/BigBoldTextInputLabel"
                app:hintTextColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/endDateLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/et_top_margin">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etReason"
                    android:inputType="text"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApply"
                android:layout_width="@dimen/no_width"
                android:layout_height="@dimen/add_emp_btn_height"
                android:text="@string/apply"
                android:textAllCaps="false"
                android:textSize="@dimen/common_text_size"
                android:backgroundTint="@color/add_emp_btn"
                android:textColor="@android:color/white"
                app:cornerRadius="@dimen/card_radius"
                app:layout_constraintTop_toBottomOf="@id/reasonLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/add_emp_top_margin"
                android:layout_marginBottom="@dimen/add_emp_bottom_margin"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>