<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/common_margin"
    android:backgroundTint="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/common_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            tools:ignore="UseCompoundDrawables">

            <ImageView
                android:id="@+id/imgClockIcon"
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:src="@drawable/ic_clock"
                android:layout_marginEnd="@dimen/icon_margin"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/txtTimeTrackingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_tracking"
                android:textSize="@dimen/icon_text_size"
                android:textColor="@color/black"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_margin"
            android:orientation="horizontal"
            android:weightSum="2"
            tools:ignore="DisableBaselineAlignment">

            <LinearLayout
                android:layout_width="@dimen/nowidth"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding"
                android:layout_marginEnd="@dimen/common_margin"
                android:background="@drawable/bg_layout_radius">

                <ImageView
                    android:id="@+id/imgClockInIcon"
                    android:layout_width="@dimen/img_icon_size"
                    android:layout_height="@dimen/img_icon_size"
                    android:src="@drawable/ic_clock"
                    android:tint="@color/grey"
                    android:background="@drawable/bg_circle_icon"
                    android:padding="@dimen/img_icon_padding"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="@dimen/icon_margin"
                    tools:ignore="ContentDescription,UseAppTint" />

                <LinearLayout
                    android:layout_width="@dimen/no_width"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    tools:ignore="InefficientWeight,NestedWeights">

                    <TextView
                        android:id="@+id/txtClockIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/clock_in"
                        android:textSize="@dimen/clock_text_size"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchClockIn"
                    android:layout_width="@dimen/switch_width"
                    android:layout_height="wrap_content"
                    android:thumb="@drawable/switch_design"
                    app:track="@drawable/switch_track"
                    app:showText="false"
                    app:splitTrack="false"
                    tools:ignore="MissingConstraints" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding"
                android:background="@drawable/bg_layout_radius">

                <ImageView
                    android:id="@+id/imgBreakInIcon"
                    android:layout_width="@dimen/img_icon_size"
                    android:layout_height="@dimen/img_icon_size"
                    android:src="@drawable/ic_local_cafe"
                    android:tint="@color/grey"
                    android:background="@drawable/bg_circle_icon"
                    android:padding="@dimen/img_icon_padding"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="@dimen/icon_margin"
                    tools:ignore="ContentDescription,UseAppTint" />

                <LinearLayout
                    android:layout_width="@dimen/no_width"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    tools:ignore="InefficientWeight,NestedWeights">

                    <TextView
                        android:id="@+id/txtBreakIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/break_in"
                        android:textSize="@dimen/clock_text_size"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBreak"
                    android:layout_width="@dimen/switch_width"
                    android:layout_height="wrap_content"
                    android:thumb="@drawable/switch_design"
                    app:track="@drawable/switch_track"
                    app:showText="false"
                    android:enabled="false"
                    app:splitTrack="false"/>

            </LinearLayout>

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_margin"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/work_time_card_color"
                app:cardCornerRadius="@dimen/card_radius"
                android:layout_marginEnd="@dimen/common_margin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/time_card_padding"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtWorkTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/work_time"
                        android:textSize="@dimen/time_text_size"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"/>

                    <TextView
                        android:id="@+id/txtWorkTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_time"
                        android:textStyle="bold"
                        android:textSize="@dimen/timer_text_size"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/no_width"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/break_time_card_color"
                app:cardCornerRadius="@dimen/card_radius">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/time_card_padding"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtBreakTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/break_time"
                        android:textSize="@dimen/time_text_size"
                        android:textStyle="bold"
                        android:textColor="@color/break_time_text_color"/>

                    <TextView
                        android:id="@+id/txtBreakTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_time"
                        android:textStyle="bold"
                        android:textSize="@dimen/timer_text_size"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>